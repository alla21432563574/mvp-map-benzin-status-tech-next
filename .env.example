NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_SECRET=change-this-long-random-secret
CRON_SECRET=change-this-to-a-separate-random-secret

# Основной production-домен приложения
NEXT_PUBLIC_SITE_URL=https://24benz.ru
NEXT_PUBLIC_APP_URL=https://24benz.ru
SITE_URL=https://24benz.ru
APP_URL=https://24benz.ru

# Карточная подложка. Для РФ можно заменить на быстрый/локальный tile CDN,
# сохранив шаблон {z}/{x}/{y} и корректную attribution провайдера.
NEXT_PUBLIC_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>

# Безопасный импорт публично видимых данных map.benzin-status.tech
SCRAPER_ENABLED=false
SCRAPER_INTERVAL_SECONDS=180
SCRAPER_MODE=russia
SCRAPER_CITY=Россия
SCRAPER_CITY_CENTER_LAT=55.7558
SCRAPER_CITY_CENTER_LNG=37.6173
SCRAPER_GRID_STEP_DEGREES=4
SCRAPER_MAX_STATIONS_PER_RUN=5000
SCRAPER_REQUEST_DELAY_MS=250
SCRAPER_REPORTS_MODE=incremental
SCRAPER_REPORT_LOOKBACK_HOURS=2
SCRAPER_MAX_REPORT_STATIONS=2000
SCRAPER_BOUNDS=55.40,36.80,56.10,38.40
SCRAPER_LOCK_SECONDS=3600
SCRAPER_MIN_SNAPSHOT_RATIO=0.85
SCRAPER_MISSING_RUNS_BEFORE_DEACTIVATE=3
SCRAPE_LOG_RETENTION_DAYS=30
